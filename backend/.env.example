# Copy this file to .env and fill in keys for the providers you want to use.
# REED detects which providers are available based on which keys are set.
# No default provider. You pick.

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenRouter (covers most OpenAI-compatible providers when used with custom base_url)
OPENROUTER_API_KEY=

# Ollama (local: no key needed; cloud: API key required)
OLLAMA_API_KEY=
OLLAMA_HOST=http://localhost:11434

# Trigger endpoint auth (set both to enable external cron triggers)
REED_TRIGGER_TOKEN=

# Storage mode (local | mirror). Default: local.
# REED_STORE=local

# Hugging Face Dataset mirror (required when REED_STORE=mirror)
HF_DATASET_REPO=
HF_TOKEN=

# Search provider (ddgs | brave | tavily). Default: ddgs.
# REED_SEARCH_PROVIDER=ddgs

# Brave Search (optional)
BRAVE_API_KEY=

# Tavily (optional)
TAVILY_API_KEY=
